# ── RPC endpoints ────────────────────────────────────────────────────────────
RPC_HTTPS=https://api.mainnet-beta.solana.com
RPC_WSS=wss://api.mainnet-beta.solana.com

# ── Wallet ───────────────────────────────────────────────────────────────────
PRIVATE_KEY=<base58-encoded-private-key>

# ── Snipe settings ───────────────────────────────────────────────────────────
# SOL amount to spend on each new pool (e.g. 0.1 = 0.1 SOL)
BUY_AMOUNT=0.1
# Slippage tolerance in percent (e.g. 10 = 10 %)
SLIPPAGE=10
# Set to false to send via standard RPC instead of Jito
USE_JITO=true

# ── Jito ─────────────────────────────────────────────────────────────────────
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
# Fixed tip in SOL (overrides percentile-based tip when set)
JITO_TIP_VALUE=0.004

# ── Compute budget (non-Jito only) ───────────────────────────────────────────
UNIT_PRICE=100000
UNIT_LIMIT=300000
